[Unit]
Description=Launch the Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
User=ec2-user
WorkingDirectory=/LiamRanaIsaac
Environment=JAVA_HOME=/usr/lib/jvm/java-26-amazon-corretto.x86_64
ExecStart=/usr/lib/jvm/java-26-amazon-corretto.x86_64/bin/java -jar target/WatchlistBot-1.0.0-jar-with-dependencies.jar
Restart=on-failure

[Install]
WantedBy=multi-user.target